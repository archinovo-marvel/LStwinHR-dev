REACT_APP_VIRTUAL_HUMAN_ENABLED=true

# JWT密钥
JWT_SECRET=your_jwt_secret_here

# Ollama配置（默认值，docker-compose中会覆盖）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# 本地VL模型配置（宿主机直接测试用）
LOCAL_LLM_ENABLED=true
LOCAL_LLM_VL_URL=http://localhost:8000
LOCAL_LLM_VL_MODEL=qwen3.5-9b-vlm-gguf

# DeepSeek API配置（简历分析功能需要）
DEEPSEEK_API_KEY=sk-327f185740dd409897a6924ca0cee9a3
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 数据库连接池（高并发调优）
DB_CONNECTION_LIMIT=50
DB_QUEUE_LIMIT=200

# AI分析并发控制（高并发调优）
RESUME_ANALYSIS_MAX_CONCURRENCY=5
RESUME_ANALYSIS_MAX_QUEUE=50
LOCAL_AI_MAX_CONCURRENCY=4
LOCAL_AI_MAX_QUEUE=20

# Node.js I/O线程池（提升文件读写并发）
UV_THREADPOOL_SIZE=128

# 简历文件处理优化（跳过非必要的CPU密集型操作）
RESUME_SKIP_HASH=true
RESUME_SKIP_JIMP=true

# 上传存储模式: memory=内存Buffer(高并发推荐), disk=传统磁盘临时文件
UPLOAD_STORAGE_MODE=memory
# 上传频率限制: 每IP每分钟最大请求数, 0=禁用 (招聘会建议500+)
UPLOAD_RATE_LIMIT_MAX=500
# 文件写入并发数(避免高并发时内核I/O缓冲区耗尽)
FILE_WRITE_CONCURRENCY=16

# 验证码模式: console=打印到日志不发送邮件, email=真实发送
EMAIL_VERIFICATION_MODE=console

# 邮件服务配置
EMAIL_HOST=smtp.exmail.qq.com
EMAIL_PORT=465
EMAIL_USER=gaolu@lstwin.top
